MONGODB_URI=mongodb://127.0.0.1:27017/mysite
JWT_SECRET=replace-with-random-256-bit-secret
# Production (Docker on ronencohen.dev):
# CLIENT_URL=https://ronencohen.dev
# ADMIN_PASSWORD=your-secure-password
# JWT_SECRET=long-random-string
CLIENT_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
# Production (Docker): PORT=80, CLIENT_URL=http://YOUR_SERVER_IP_OR_DOMAIN
# Stop host nginx before `docker compose up -d` if it already uses port 80.
# Admin panel: /ronen — auth is ALWAYS on in production. Set ADMIN_PASSWORD on the server.
# Dev only: ADMIN_AUTH_ENABLED=true to test the login form locally.
ADMIN_AUTH_ENABLED=false
ADMIN_PASSWORD=your-secure-password-here
VITE_API_URL=
# n8n Form Trigger — Production form URL (from n8n Form node)
N8N_CONTACT_WEBHOOK_URL=https://ronenc7.app.n8n.cloud/form/2f8dae89-1889-4f56-85e4-29415c62a99e
VITE_N8N_CONTACT_WEBHOOK_URL=https://ronenc7.app.n8n.cloud/form/2f8dae89-1889-4f56-85e4-29415c62a99e
